{
  "name": "webpage-channel",
  "version": "1.0.1",
  "description": "A lightweight library for cross-context communication between browser tabs, iframes, and web workers using broadcast channels and postMessage.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write 'src/**/*.{ts,tsx}'"
  },
  "keywords": [
    "broadcast channel",
    "message channel",
    "web worker",
    "iframe",
    "postMessage",
    "cross-origin communication",
    "多标签页通信",
    "跨域通信",
    "web worker通信",
    "iframe通信"
  ],
  "author": "wansongtao",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/ui": "4.1.0",
    "eslint": "^10.0.3",
    "happy-dom": "^20.8.4",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wansongtao/webpage-channel.git"
  },
  "bugs": {
    "url": "https://github.com/wansongtao/webpage-channel/issues"
  },
  "homepage": "https://github.com/wansongtao/webpage-channel#readme"
}